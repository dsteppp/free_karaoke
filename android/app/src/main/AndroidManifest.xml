<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Доступ к интернету (для загрузки обложек из Genius) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FreeKaraoke"
        android:usesCleartextTraffic="false"
        tools:targetApi="34">

        <!-- Главный экран — Медиатека -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FreeKaraoke"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Обработка ZIP-файлов для импорта -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/zip" />
                <data android:host="*" />
                <data android:scheme="content" />
                <data android:scheme="file" />
            </intent-filter>
        </activity>

        <!-- Редактор таймингов -->
        <activity
            android:name=".editor.TimingEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.FreeKaraoke"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <!-- Редактор метаданных -->
        <activity
            android:name=".editor.MetadataEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.FreeKaraoke"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

    </application>

</manifest>
