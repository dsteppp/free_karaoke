# ╔══════════════════════════════════════════════════════════════════╗
# ║  ⚠️  ИЗМЕНИ МЕНЯ! ЭТО ШАБЛОН — ОН НЕ РАБОТАЕТ БЕЗ ТВОИХ ДАННЫХ  ║
# ║  Скопируй этот файл, вставь свои токены и переименуй в .env      ║
# ║  Команда: cp .env.example .env                                   ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Токен Genius API (для поиска текстов песен) ─────────────────────
# Получи бесплатно за 2 минуты: https://genius.com/api-clients/new
# Создай клиент, скопируй "Access Token" и вставь сюда:
GENIUS_ACCESS_TOKEN=INSERT_YOUR_GENIUS_TOKEN_HERE

# ── Токен HuggingFace (опционально) ─────────────────────────────────
# Получи бесплатно: https://huggingface.co/settings/tokens
# Создай токен с ролью "Read" и вставь сюда:
# Примечание: Whisper medium скачивается без токена, HF_TOKEN нужен
#             только для некоторых дополнительных моделей
# HF_TOKEN=INSERT_YOUR_HUGGINGFACE_TOKEN_HERE

# ── Порт сервера (можно не менять) ───────────────────────────────────
APP_PORT=8000

# ════════════════════════════════════════════════════════════════════
# ENGLISH VERSION
# ════════════════════════════════════════════════════════════════════

# ⚠️  EDIT ME! THIS IS A TEMPLATE — IT WON'T WORK WITHOUT YOUR DATA  #
# Copy this file, insert your tokens and rename to .env              #
# Command: cp .env.example .env                                      #

# ── Genius API Token (for lyrics lookup) ────────────────────────────
# Get free in 2 minutes: https://genius.com/api-clients/new
# Create a client, copy "Access Token" and paste here:
# GENIUS_ACCESS_TOKEN=INSERT_YOUR_GENIUS_TOKEN_HERE

# ── HuggingFace Token (optional) ────────────────────────────────────
# Get free at: https://huggingface.co/settings/tokens
# Create token with "Read" role and insert here:
# Note: Whisper medium downloads without token, HF_TOKEN is only needed
#       for some additional models
# HF_TOKEN=INSERT_YOUR_HUGGINGFACE_TOKEN_HERE

# ── Server port (no need to change) ─────────────────────────────────
# APP_PORT=8000