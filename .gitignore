# ── Создаётся автоматически при установке ──────────────
.venv/
.env.cache
requirements.txt

# ── Создаётся автоматически при работе ─────────────────
cache/
models/
library/
debug_logs/
*.db
*.db-shm
*.db-wal

# ── Секреты пользователя ───────────────────────────────
.env

# ── Python-мусор ───────────────────────────────────────
__pycache__/
*.pyc

# ── Бэкапы (_back в имени, любой регистр) ─────────────
*_[Bb][Aa][Cc][Kk]*