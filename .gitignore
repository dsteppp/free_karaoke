# ═══════════════════════════════════════════════════════
# Free Karaoke — .gitignore
# ═══════════════════════════════════════════════════════

# ── Пользовательские данные (core) ─────────────────────
core/cache/
core/debug_logs/
core/library/
core/models/
core/*.db
core/*.db-shm
core/*.db-wal
core/huey_queue.db
core/huey_queue.db-*
core/__pycache__/
core/*.pyc
core/.venv/
core/venv/

# ── Секреты пользователя ───────────────────────────────
core/.env
core/.env.cache
core/portable.env

# ── Скрипты сборки — временная директория ─────────────
releases/_build/
releases/_build-cache/
releases/*.AppImage
releases/*.apk
releases/FreeKaraoke-*/
releases/core/

# ── Собранные артефакты ────────────────────────────────
dist/
build/
*.AppImage
*.apk
*.aab
Free_Karaoke/
FreeKaraoke/

# ── Python ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# ── IDE ────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*~

# ── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
