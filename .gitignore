# ═══════════════════════════════════════════════════════
# Free Karaoke — Монорепозиторий .gitignore
# ═══════════════════════════════════════════════════════

# ── Файлы верхнего уровня (перемещены в core/) ─────────
# Эти файлы остались от старой структуры — игнорируем
*.db
*.db-shm
*.db-wal
cache/
library/
models/
debug_logs/
__pycache__/
.venv/

# ── ML-модели (большие файлы, скачиваются при сборке) ──
desktop/shared/models/*.bin
desktop/shared/models/*.pt
desktop/shared/models/*.onnx
desktop/shared/models/*.pth
desktop/shared/models/*.h5
core/models/

# ── Собранные артефакты ────────────────────────────────
dist/
build/
*.AppImage
*.apk
*.aab
*.exe
FreeKaraoke-*/
Free_Karaoke/

# ── Кэши и временные файлы (core) ─────────────────────
core/cache/
core/debug_logs/
core/library/
core/models/
core/*.db
core/*.db-shm
core/*.db-wal
core/huey_queue.db
core/huey_queue.db-*

# ── Кэши Python ────────────────────────────────────────
core/__pycache__/
core/*.pyc
core/*.pyo
core/.venv/
core/venv/

# ── Секреты пользователя ───────────────────────────────
core/.env
core/.env.cache
core/requirements.txt

# ── Библиотека пользователя (core) ─────────────────────
core/library/

# ── Android ────────────────────────────────────────────
android/.gradle/
android/.idea/
android/app/build/
android/local.properties
android/captures/
android/*.jks
android/*.keystore

# ── Desktop packaging ──────────────────────────────────
desktop/windows/build/
desktop/linux/build/
desktop/linux/*.AppImage

# ── IDE ────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*~

# ── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Бэкапы (_back в имени, любой регистр) ─────────────
# Но НЕ editor_backend.py и подобные рабочие файлы
*_[Bb][Aa][Cc][Kk]_[Bb][Aa][Cc][Kk]*
