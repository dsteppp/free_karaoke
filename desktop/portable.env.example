# ═══════════════════════════════════════════════════════
# Free Karaoke — Portable Environment (шаблон)
# Копируется в desktop/portable.env при сборке
# ═══════════════════════════════════════════════════════

# ── Токены API ─────────────────────────────────────────
GENIUS_ACCESS_TOKEN=ВСТАВЬ_СЮДА_СВОЙ_GENIUS_TOKEN
HF_TOKEN=ВСТАВЬ_СЮДА_СВОЙ_HUGGINGFACE_TOKEN

# ── Порт сервера (Desktop) ─────────────────────────────
APP_PORT=8000

# ── Пути (заполняются автоматически при сборке) ────────
# MODELS_DIR=./_runtime/models
# CACHE_DIR=./_runtime/cache
# LIBRARY_DIR=./library
# CONFIG_DIR=./config

# ── Whisper модель ─────────────────────────────────────
WHISPER_MODEL=medium

# ── Логирование ────────────────────────────────────────
LOG_LEVEL=INFO
